# OpenCode Zen API Configuration
# Sign in at https://opencode.ai/zen to get your API key
OPENCODE_ZEN_API_KEY=your_api_key_here

# OpenCode Zen base URL (OpenAI-compatible endpoint)
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# Model to use — must be an OpenAI-compatible model from Zen
# e.g. deepseek-v4-pro, deepseek-v4-flash, glm-5.1, kimi-k2.5
OPENCODE_ZEN_MODEL=deepseek-v4-flash

# ── GitHub MCP Server ──────────────────────────────────────────────────────
# Requires Node.js / npx (the server is auto-installed on first run via npx)
# Generate a token at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user (add workflow for Actions access)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
